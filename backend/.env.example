# ── Stocker backend ─────────────────────────────────────────────────────────────
# Multi-user auth: sign JWT sessions. Use a long random string in production.
JWT_SECRET=change-me-in-production

# ── Phase 3: broker token encryption at rest (AES-256-GCM) ────────────────────
# Generate a fresh key:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes = 256 bits).
# If unset: tokens are stored as plaintext (fine for local dev, NOT for production).
# IMPORTANT: once set, never change this key without re-saving all broker connections.
TOKEN_ENCRYPTION_KEY=

# Your Paytm Money API credentials. The secret stays server-side only — NEVER expose it.
PAYTM_API_KEY=
PAYTM_API_SECRET=

# ── Turso database (token persistence) ─────────────────────────────────────────
# The Paytm session is stored here so restarts don't force a re-login.
TURSO_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

# Where the React frontend runs — used for CORS and the local login redirect.
FRONTEND_URL=http://localhost:5173

# Port for this backend.
PORT=5174

# ── INDmoney / INDstocks provider (US + Indian stocks) — optional ──────────────
# A single API key is enough (no secret needed) — it's sent as the bearer token.
INDMONEY_API_KEY=
INDMONEY_API_SECRET=
# Base URL defaults to https://api.indstocks.com; paths default to /portfolio/holdings,
# /market/quotes, /market/historical. Override any of these if the docs differ.
INDSTOCKS_API_BASE=https://api.indstocks.com
# INDSTOCKS_AUTH_HEADER=Authorization
# INDSTOCKS_AUTH_SCHEME=Bearer␣      (set empty for a bare token, no "Bearer " prefix)
# INDSTOCKS_PATH_HOLDINGS=/portfolio/holdings
# INDSTOCKS_PATH_QUOTE=/market/quotes
# NOTE: INDstocks requires a whitelisted STATIC IP for API access — your backend host's
# outbound IP must be added in the INDstocks Algo Trading Portal, or calls will be blocked.

# ── Alert engine scheduler (Phase 4) — DEPLOY-ONLY ─────────────────────────────
# Set to 'true' on the deployed backend to run the cron poll + EOD NAV snapshot.
# Leave unset locally (the sandbox can't reach Paytm); use POST /api/alerts/evaluate-now.
ENABLE_SCHEDULER=

# ── Email alert channel (SMTP) — optional, deploy-only ─────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ALERT_EMAIL_TO=

# ── AI Portfolio Analyst + Copilot (any OpenAI-compatible LLM) — optional ──────
# Configure ANY provider via these (OpenRouter, ZenMux/GLM, OpenAI, …):
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=liquid/lfm-2.5-1.2b-thinking:free
# Example for GLM 5.2 via ZenMux:
#   LLM_BASE_URL=https://zenmux.ai/api/v1
#   LLM_MODEL=z-ai/glm-5.2
#   LLM_API_KEY=sk-ai-...
# Legacy fallbacks (still honored): OPENROUTER_API_KEY / OPENROUTER_MODEL
OPENROUTER_SITE_URL=https://stocker-2-0-frontend.vercel.app
OPENROUTER_SITE_NAME=Stocker

# ── Market data (AlphaVantage) — global quotes/history/fundamentals/movers ─────
ALPHAVANTAGE_API_KEY=
