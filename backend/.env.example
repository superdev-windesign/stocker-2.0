# ── Stocker backend (Express token helper + Paytm REST proxy) ──────────────────
# Your Paytm Money API credentials. The secret stays server-side only — NEVER expose it.
PAYTM_API_KEY=
PAYTM_API_SECRET=

# ── Turso database (token persistence) ─────────────────────────────────────────
# The Paytm session is stored here so restarts don't force a re-login.
TURSO_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

# Where the React frontend runs — used for CORS and the local login redirect.
FRONTEND_URL=http://localhost:5173

# Port for this backend.
PORT=5174
