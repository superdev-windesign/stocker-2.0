# ── Stocker backend (Express token helper + Paytm REST proxy) ──────────────────
# Your Paytm Money API credentials. The secret stays server-side only — NEVER expose it.
PAYTM_API_KEY=
PAYTM_API_SECRET=

# ── Turso database (token persistence) ─────────────────────────────────────────
# The Paytm session is stored here so restarts don't force a re-login.
TURSO_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

# Where the React frontend runs — used for CORS and the local login redirect.
FRONTEND_URL=http://localhost:5173

# Port for this backend.
PORT=5174

# ── INDmoney / INDstocks provider (US + Indian stocks) — optional ──────────────
INDMONEY_API_KEY=
INDMONEY_API_SECRET=
# Base URL + (optional) path/header overrides for the INDstocks REST API.
INDSTOCKS_API_BASE=
# INDSTOCKS_AUTH_HEADER=Authorization
# INDSTOCKS_PATH_HOLDINGS=/holdings

# ── Alert engine scheduler (Phase 4) — DEPLOY-ONLY ─────────────────────────────
# Set to 'true' on the deployed backend to run the cron poll + EOD NAV snapshot.
# Leave unset locally (the sandbox can't reach Paytm); use POST /api/alerts/evaluate-now.
ENABLE_SCHEDULER=

# ── Email alert channel (SMTP) — optional, deploy-only ─────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ALERT_EMAIL_TO=

# ── AI Portfolio Analyst (OpenRouter) — optional, deploy-only ──────────────────
# Without a key the analyst falls back to deterministic heuristic summaries.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o
OPENROUTER_SITE_URL=https://stocker-2-0-frontend.vercel.app
OPENROUTER_SITE_NAME=Stocker
