# ── Stocker frontend (Vite) — only VITE_* vars are exposed to the browser ──────
# Base URL of the Stocker backend. In dev this defaults to http://localhost:5174
# when unset; set it explicitly to point at a deployed backend.
VITE_BACKEND_URL=http://localhost:5174

# Optional: pre-fill a Paytm public access token manually instead of using the login flow.
VITE_PAYTM_PUBLIC_ACCESS_TOKEN=
